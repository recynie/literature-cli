# OpenAI API key (required for local chat interface and summarization)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI-compatible API base URL (optional, defaults to https://api.openai.com/v1)
# Use this for compatible providers or local gateways. Include /v1 when required.
# OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI model for LLM tasks (optional, defaults to gpt-4o-mini for extraction;
# some summary paths default to gpt-4o when OPENAI_MODEL is unset)
OPENAI_MODEL=gpt-4o-mini

# OpenAI completion options (optional)
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# Number of PDF pages used for LLM paper summarization (optional, defaults to 10)
PAPERCLI_PDF_PAGES=10

# Data directory for database and PDFs (optional, defaults to ~/.papercli)
PAPERCLI_DATA_DIR=/path/to/your/papercli/data
